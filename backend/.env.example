# SAMAS API Keys
# Rename this file to .env and replace placeholders with your actual keys.

# OpenRouter (for LLM inference)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub (for scraping candidate repos)
GITHUB_TOKEN=your_github_token_here

# SerpAPI (for job searches)
SERPAPI_API_KEY=your_serpapi_api_key_here

# Apify (for web scraping)
APIFY_TOKEN=your_apify_token_here

# Pinecone (for vector DB)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=samas-index

# LangSmith (Optional for tracing)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=samas-backend
